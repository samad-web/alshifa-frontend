# ⚠️  IMPORTANT: These Supabase keys were previously committed to git.
#    You MUST rotate them at https://supabase.com/dashboard → Project Settings → API Keys
#    Then replace the placeholder values below with the NEW keys.

VITE_SUPABASE_PROJECT_ID="REPLACE_WITH_NEW_PROJECT_ID"
VITE_SUPABASE_PUBLISHABLE_KEY="REPLACE_WITH_NEW_ANON_KEY"
VITE_SUPABASE_URL="REPLACE_WITH_NEW_SUPABASE_URL"

# Backend API base URL — required, app will not work without this
VITE_API_BASE_URL="http://localhost:4000"
